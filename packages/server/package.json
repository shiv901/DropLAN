    "express": "^4.18.2",
    "multer": "^2.1.1",
    "socket.io": "^4.7.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "vitest": "^1.1.0"
  }
}
