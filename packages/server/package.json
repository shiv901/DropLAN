{
  "name": "@droplan/server",
  "version": "0.1.0",
  "description": "Express server and transfer engine",
  "main": "../../dist/server/main.js",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "node ../../dist/server/main.js",
    "build": "tsc && cp -r src/browser-ui ../../dist/server/browser-ui",
